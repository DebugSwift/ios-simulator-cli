{
  "name": "@debugswift/ios-simulator-cli",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.7.0",
  "description": "CLI for interacting with the iOS simulator",
  "bin": {
    "ios-simulator-cli": "build/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DebugSwift/ios-simulator-cli.git"
  },
  "files": [
    "build",
    "package.json"
  ],
  "scripts": {
    "prepare": "npm run build",
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "start": "node build/index.js",
    "watch": "tsc --watch"
  },
  "keywords": [
    "ios",
    "simulator",
    "cli",
    "simctl",
    "idb"
  ],
  "author": {
    "name": "Joshua Yoes",
    "url": "https://joshuayoes.com"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "typescript": "^5.5.4"
  }
}
